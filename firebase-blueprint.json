{
  "entities": {
    "RSVP": {
      "title": "RSVP",
      "description": "Confirmation de présence pour le baptême de Candice",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nom de la famille ou de la personne"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Adresse email de contact"
        },
        "adults": {
          "type": "number",
          "description": "Nombre d'adultes"
        },
        "children": {
          "type": "number",
          "description": "Nombre d'enfants"
        },
        "attendingCeremony": {
          "type": "boolean",
          "description": "Présence à la cérémonie"
        },
        "attendingLunch": {
          "type": "boolean",
          "description": "Présence au déjeuner"
        },
        "attendingDinner": {
          "type": "boolean",
          "description": "Présence au dîner"
        },
        "sleepingOnSite": {
          "type": "boolean",
          "description": "Dort sur place"
        },
        "notAttending": {
          "type": "boolean",
          "description": "Ne sera pas présent"
        },
        "dietaryRequirements": {
          "type": "string",
          "description": "Allergies ou régimes particuliers"
        },
        "message": {
          "type": "string",
          "description": "Message pour Candice"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp de création"
        }
      },
      "required": ["name", "adults", "children", "attendingCeremony", "attendingLunch", "attendingDinner", "sleepingOnSite", "notAttending", "createdAt"]
    }
  },
  "firestore": {
    "/rsvps/{rsvpId}": {
      "schema": "RSVP",
      "description": "Collection des confirmations de présence"
    }
  }
}
